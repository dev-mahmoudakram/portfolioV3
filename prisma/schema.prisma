generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  description     String   @db.Text
  longDescription String?  @db.Text
  image           String?
  techStack       Json
  category        String
  categories      String[] @default([])
  sortOrder       Int      @default(0)
  liveUrl         String?
  githubUrl       String?
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([featured])
  @@index([sortOrder])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  status    String   @default("NEW")
  createdAt DateTime @default(now())

  @@index([status])
}

model Skill {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([category])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}
