{
  "name": "mahmoud-akram-portfolio",
  "private": true,
  "version": "0.1.0",
  "description": "Premium purple neon personal portfolio monorepo for Mahmoud Akram.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspaces=false --prefix apps/web run dev",
    "build:types": "npm --workspaces=false --prefix packages/types run build",
    "build:web": "npm --workspaces=false --prefix apps/web run build",
    "build": "npm --workspaces=false --prefix packages/types run build && npm --workspaces=false --prefix apps/web run build",
    "lint": "npm --workspaces=false --prefix apps/web run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,scss,css,prisma}\"",
    "prisma:generate": "npm --workspaces=false --prefix apps/web run prisma:generate",
    "prisma:migrate": "npm --workspaces=false --prefix apps/web run prisma:migrate:dev",
    "prisma:migrate:deploy": "npm --workspaces=false --prefix apps/web run prisma:migrate:deploy",
    "prisma:seed": "npm --workspaces=false --prefix apps/web run prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  }
}
