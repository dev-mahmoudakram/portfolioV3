{
  "name": "mahmoud-akram-portfolio",
  "private": true,
  "version": "0.1.0",
  "description": "Premium purple neon personal portfolio monorepo for Mahmoud Akram.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspaces=false --prefix apps/web run dev",
    "dev:api": "npm --workspaces=false --prefix apps/api run start:dev",
    "build:types": "npm --workspaces=false --prefix packages/types run build",
    "build:web": "npm --workspaces=false --prefix apps/web run build",
    "build:api": "npm --workspaces=false --prefix apps/api run build",
    "build": "npm --workspaces=false --prefix packages/types run build && npm --workspaces=false --prefix apps/api run build && npm --workspaces=false --prefix apps/web run build",
    "deploy:plesk:web": "node scripts/prepare-plesk-web.mjs",
    "deploy:plesk": "npm run deploy:plesk:web",
    "lint": "npm --workspaces=false --prefix apps/web run lint && npm --workspaces=false --prefix apps/api run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,scss,css,prisma}\"",
    "prisma:migrate": "npm --workspaces=false --prefix apps/api run prisma:migrate",
    "prisma:seed": "npm --workspaces=false --prefix apps/api run prisma:seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5"
  }
}
